{
  "name": "@ramarivera/pi-grok-build",
  "version": "0.1.3",
  "description": "Pi extension providing Grok Build / Grok CLI integration.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramarivera/pi-grok-build.git"
  },
  "bugs": {
    "url": "https://github.com/ramarivera/pi-grok-build/issues"
  },
  "homepage": "https://github.com/ramarivera/pi-grok-build#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "grok",
    "xai",
    "grok-cli"
  ],
  "scripts": {
    "test": "npm run test:unit && npm run test:property",
    "test:unit": "tsx --test test/unit/**/*.test.ts",
    "test:property": "tsx --test test/property/**/*.property.test.ts",
    "test:ci": "npm run typecheck && npm run test:unit && npm run test:property",
    "test:e2e": "npm run test:e2e:sdk && npm run test:e2e:grok",
    "test:e2e:sdk": "tsx --test test/e2e/sdk/**/*.e2e.test.ts",
    "test:e2e:grok": "tsx --test test/e2e/manual/**/*.test.ts test/e2e/manual/**/*.e2e.test.ts",
    "test:grok": "npm run test:e2e:grok",
    "typecheck": "npm exec --package typescript -- tsc --noEmit",
    "lint": "biome lint . && npm run typecheck",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check . && npm run typecheck"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "dependencies": {
    "cross-spawn": "^7.0.6",
    "effect": "^3.21.2",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^25.0.0",
    "fast-check": "^4.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0"
  }
}
